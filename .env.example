# Environment: dev (local) or production (VPS)
ENVIRONMENT=dev

# Development bot token (used when ENVIRONMENT=dev)
BOT_TOKEN_DEV=YOUR_DEV_BOT_TOKEN

# Production bot token (used when ENVIRONMENT=production)
BOT_TOKEN_PROD=YOUR_PROD_BOT_TOKEN

# Webhook URL (required for production only; optional for dev - dev uses long polling)
WEBHOOK_URL=https://your-app.onrender.com/webhook

# Optional: comma-separated Telegram user IDs for Admin Panel (default: 6013044386)
# ADMIN_IDS=6013044386
# For dev, add your Telegram user ID so the Admin Panel button appears and works.
# DB_PATH=data/behavebot.db
# FEEDBACK_DIR=data/feedback
# DEXSCREENER_BASE=https://api.dexscreener.com/latest/dex/tokens

# RPC endpoints for wallet monitoring (required for BNB, Base, Solana auto-detection)
# Solana: use mainnet (not devnet). Example: https://rpc.ankr.com/solana/<API_KEY>
SOL_RPC=
BNB_RPC=
BASE_RPC=

# Premium: USDC on Base — wallet that receives manual payments (default set in config)
# PAYMENT_BASE_USDC_WALLET=0x0156650a2b571f28aa0c50fc4cf34ea6789efb74
